<Page x:Class="nio2so.TSOView2.Formats.Terrain.TSOCityViewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:nio2so.TSOView2.Formats.Terrain" xmlns:obj="clr-namespace:nio2so.TSOView2.Formats.OBJ"
      mc:Ignorable="d" Foreground="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TSOView2 3D City Viewer">

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Button Name="TransmogrifierButton" Margin="10,0,0,0" Background="Green" HorizontalAlignment="Left" VerticalAlignment="Center" Width="233" Foreground="White" Click="TransmogrifierButton_Click">Send City to The Sims Online: Pre-Alpha</Button>
        <obj:MeshObjectViewer x:Name="ModelViewer" Background="{StaticResource TSOWindowBackgroundBrush}" Grid.Row="1"/>
        <Border Padding="5" Background="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Right" MaxWidth="128" Grid.Row="1">
            <Image Name="Mini_HUD_Image"/>
        </Border>
    </Grid>

</Page>
